pipeline{
    agent any
    stages{
        stage('git checkout'){
            steps{
                    checkout scmGit(branches: [[name: '*/main']], extensions: [], userRemoteConfigs: [[credentialsId: 'GitCreds', url: 'https://github.com/Subhash-Rokkala/hotstar.git']])                
            }
        }
        stage('build process'){
            steps{
            sh 'mvn clean install'
            }
        }
        stage('building custome image'){
            steps{
                sh 'docker build -t subhashrokkala/hotstar:latest .'
            }
        }
        stage('pushing image to docker hub'){
            steps{
                sh 'docker push subhashrokkala/hotsar:latest'
            }
        }
    }
}
